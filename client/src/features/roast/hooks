import { useState, useCallback } from 'react';
import api from '../services/api';

/**
 * Custom hook to handle AI roasts
 */
export const useRoast = () => {
  const [roastData, setRoastData] = useState(null);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');

  const handleRoast = useCallback(async () => {
    if (loading) return;

    setLoading(true);
    setError('');
    setRoastData(null);

    try {
      const res = await api.post('/roast');
      const data = res?.data;
      
      if (!data?.roast) {
        throw new Error('AI response missing required fields.');
      }
      
      setRoastData(data);
    } catch (err) {
      console.error('Roast hook error:', err);
      setError(err.message || 'Failed to generate roast. Please try again.');
    } finally {
      setLoading(false);
    }
  }, [loading]);

  const clearError = () => setError('');

  return {
    roastData,
    loading,
    error,
    handleRoast,
    clearError
  };
};

export default useRoast;
